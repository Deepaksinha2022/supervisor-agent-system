   "source": [
    "from typing import TypedDict\n",
    "\n",
    "class AgentState(TypedDict):\n",
    "    messages: list\n",
    "    next: str\n",
    "\n",
    "def planner_node(state: AgentState):\n",
    "    query = state[\"query\"]\n",
    "\n",
    "    return {\n",
    "        \"plan\": [\n",
    "            f\"Research: {query}\",\n",
    "            \"Summarize findings\"\n",
    "        ]\n",
    "    }"
   ]
  }
